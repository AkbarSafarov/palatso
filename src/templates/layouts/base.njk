<!doctype html>
<html lang="ru">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="description" content="{{ description | default('Палаццо') }}" />
        <meta name="robots" content="{{ robots | default('index, follow') }}" />
        <link rel="canonical" href="{{ canonical | default('https://stroynova.ru/') }}" />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@300..700&family=Manrope:wght@200..800&family=Roboto:ital,wght@0,100..900;1,100..900&family=Sansation:ital,wght@0,300;0,400;0,700;1,300;1,400;1,700&display=swap" rel="stylesheet">
        <!-- OpenGraph -->
        <meta property="og:type" content="website" />
        <meta property="og:title" content="{{ title | default('Палаццо') }}" />
        <meta property="og:description" content="{{ description | default('Палаццо') }}" />
        <meta property="og:url" content="{{ canonical | default('https://stroynova.ru/') }}" />
        <meta property="og:image" content="https://stroynova.ru/og-image.jpg" />

        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content="{{ title | default('Палаццо') }}" />
        <meta name="twitter:description" content="{{ description | default('Палаццо') }}" />

        <!-- Favicon -->
        <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

        <title>{{ title | default('Палаццо') }}</title>

        {% block head %}{% endblock %}
    </head>
  <body>

    {% if headerDark %}
      {% include "partials/header-dark.njk" %}
    {% else %}
      {% include "partials/header.njk" %}
    {% endif %}

    <main id="main-content">
      {% block content %}{% endblock %}
    </main>

    {% include "partials/footer.njk" %}


    <script type="module" src="/main.js"></script>

  </body>
</html>
