{# Modal: Заказать звонок #}
<div id="modal-contacts" class="fancybox__content modal-contacts" style="display:none;">
    <div class="modal-win modal-win--call-a-master">
        <div class="form-wrap">
            <div class="text-center">
                <div class="modal-win__title">Заполните анкету</div>
            </div>
            <form class="modal-win__form" action="/" method="POST" novalidate>
                <div class="modal-win__group">
                    <label class="modal-win__label" for="modal-name">Ваше Имя</label>
                    <input class="modal-win__input" id="modal-name" name="user_name" type="text" placeholder="Ваше Имя">
                </div>
                <div class="modal-win__group">
                    <label class="modal-win__label" for="modal-phone">Телефон</label>
                    <input class="modal-win__input" id="modal-phone" name="user_phone" type="tel" placeholder="+7 (___) ___-__-__" inputmode="tel">
                </div>
                <div class="modal-win__group">
                    <label class="modal-win__label" for="modal-email">E-mail</label>
                    <input class="modal-win__input" id="modal-email" name="user_email" type="email" placeholder="E-mail">
                </div>
                <div class="modal-win__group">
                    <label class="modal-win__label" for="modal-city">Город</label>
                    <input class="modal-win__input" id="modal-city" name="user_city" type="text" placeholder="Москва">
                </div>
                <div class="modal-win__group">
                    <label class="modal-win__label" for="modal-company">Название компании</label>
                    <input class="modal-win__input" id="modal-company" name="user_name_company" type="text" placeholder="Компания">
                </div>
                <button class="modal-win__submit" type="submit">Отправить</button>
                <p class="modal-win__policy">
                    Нажимая кнопку «Отправить» я соглашаюсь с
                    <a href="/politika/">Положением о персональных данных и конфиденциальности.</a>
                </p>
            </form>
        </div>
    </div>
</div>

